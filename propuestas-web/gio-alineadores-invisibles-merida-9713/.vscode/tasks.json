{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "static-server-8080",
      "type": "shell",
      "command": "npx -y serve . -l 8080",
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "NODE_OPTIONS": ""
        }
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "static-server",
        "pattern": [{ "regexp": ".", "file": 1, "location": 2, "message": 3 }],
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "Accepting connections at http://localhost:8080"
        }
      },
      "presentation": {
        "reveal": "silent",
        "panel": "dedicated"
      }
    }
  ]
}
